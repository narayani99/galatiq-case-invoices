# =============================================================================
# Galatiq Invoice Processing System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# LLM Setup (xAI Grok - uses OpenAI-compatible API)
# -----------------------------------------------------------------------------
GROK_API_KEY=your_api_key_here
GROK_MODEL=grok-3
GROK_API_BASE=https://api.x.ai/v1

# Fallback LLM (if Grok unavailable)
FALLBACK_LLM=openai
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_PATH=./inventory.db
DATABASE_TIMEOUT=30

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
REACT_APP_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_RESILIENCE_TESTS=false
ENABLE_MOCK_PAYMENT_FAILURES=true
MAX_RETRIES=2
RETRY_BACKOFF_FACTOR=2
